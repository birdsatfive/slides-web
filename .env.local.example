# slides.birdsatfive.dk — local dev env (mirrors ops')
# Self-hosted baf-supabase on Hetzner; cookies on `.birdsatfive.dk` give SSO.

NEXT_PUBLIC_SUPABASE_URL=https://supabase.birdsatfive.dk
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Internal JWT shared with slides-api (FastAPI render service).
# Sign with HS256 + this secret; the API verifies and trusts org_id/user_id claims.
SLIDES_API_URL=http://localhost:8000
SLIDES_API_JWT_SECRET=

# Azure AD (reuse ops app — already configured in baf-supabase Auth)
AZURE_TENANT_ID=38ce8fc0-9f24-4939-bbc0-40e28b64589b
NEXT_PUBLIC_AZURE_CLIENT_ID=6a494977-f97b-45cc-93ea-446badb91da5
AZURE_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3001
TENANT_ID=birdsatfive
